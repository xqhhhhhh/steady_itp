        <mxCell id="n65" value="runLegacyDateStep()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFBF1;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1760" y="2580" width="180" height="72" as="geometry" /></mxCell>
        <mxCell id="n66" value="其它 step: 仅日志等待" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#6B7280;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1760" y="2680" width="180" height="70" as="geometry" /></mxCell>

        <mxCell id="n70" value="Queue Health Guard&#10;1) probe 周期到?&#10;2) 连续失败&lt;4: 仅累计&#10;3) 连续失败>=4: 重度告警&#10;4) 队列&lt;=100: 只告警不切VPN&#10;5) 否则触发 VPN switch(round_robin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2F5EA7;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="100" y="3040" width="460" height="220" as="geometry" /></mxCell>
        <mxCell id="n71" value="Queue Thresholds&#10;&lt;=1000/100/10 发送钉钉(去重)&#10;跨越 50 触发 fastest 切换(可绕过冷却)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E57C2;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="610" y="3045" width="420" height="150" as="geometry" /></mxCell>
        <mxCell id="n72" value="捡漏循环控制&#10;- maybeAbortScavengeRoundByTimeout: 超时回 world + 计划下一轮&#10;- maybeRunScavengeLoopRestart: 到点 reload/assign eventUrl&#10;- shouldHoldOnWorldForScavengeWaiting: 等待窗口内暂停点击" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2F5EA7;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1070" y="3038" width="500" height="210" as="geometry" /></mxCell>
        <mxCell id="n73" value="通知消息桥（background）&#10;DINGTALK_NOTIFY: eventKey 5分钟去重&#10;ALIYUN_CALL_NOTIFY: eventKey 24小时去重&#10;VPN_HEALTH_CHECK / VPN_SWITCH_REQUEST / OCR_REQUEST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2F5EA7;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="1610" y="3038" width="530" height="210" as="geometry" /></mxCell>
        <mxCell id="n74" value="成功终止条件&#10;1) info 提交成功 -> stopLoop&#10;2) fullFlow=false 且进入 price -> stopLoop&#10;3) maybeFinishScavengeLoopIfEnabled 命中 -> stopLoop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAFBF1;strokeColor=#2E7D32;strokeWidth=1.5;" vertex="1" parent="1"><mxGeometry x="2180" y="3048" width="460" height="180" as="geometry" /></mxCell>
        <mxCell id="n75" value="详细阶段 if/else 见下一页&#10;02-详细子流程" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#B08900;strokeWidth=1.5;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2680" y="3095" width="240" height="90" as="geometry" /></mxCell>

