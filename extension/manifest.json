{
  "manifest_version": 3,
  "name": "NOL Ticket Fast Helper",
  "version": "0.1.0",
  "description": "Request-first and click-fallback helper for NOL ticket purchase flow.",
  "key": "",
  "permissions": ["storage", "tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "https://*/*",
    "https://world.nol.com/*",
    "https://tickets.interpark.com/*",
    "https://secureapi.ext.eximbay.com/*",
    "https://oapi.dingtalk.com/*",
    "https://*.dingtalk.com/*",
    "https://*.globalinterpark.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://gpoticket.globalinterpark.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NOL Ticket Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://world.nol.com/*",
        "https://tickets.interpark.com/*",
        "https://secureapi.ext.eximbay.com/*",
        "https://gpoticket.globalinterpark.com/*" 
      ],
      "js": ["content/captcha-engine.js", "content-script.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
